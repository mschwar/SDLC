#!/usr/bin/env bash
set -euo pipefail

MSG_FILE="$1"
MSG=$(head -1 "$MSG_FILE")
PATTERN='^(feat|fix|docs|chore|refactor|test|style|perf|ci|build|revert)(\(.+\))?: .+'

if ! echo "$MSG" | grep -qE "$PATTERN"; then
    echo "ERROR: commit message must follow conventional commit format."
    exit 1
fi
