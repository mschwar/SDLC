{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mschwar/SDLC/blob/main/repo-manifest.schema.json",
  "title": "SDLC Repo Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile",
    "repository",
    "product",
    "service",
    "docs",
    "quality",
    "environments",
    "controls"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "starter_kit",
        "operating_model"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "starter_kit": {
          "type": "string",
          "minLength": 1
        },
        "operating_model": {
          "type": "string",
          "enum": [
            "small-team-service"
          ]
        }
      }
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "slug",
        "visibility",
        "default_branch"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "visibility": {
          "type": "string",
          "enum": [
            "private",
            "public"
          ]
        },
        "default_branch": {
          "type": "string",
          "enum": [
            "main"
          ]
        }
      }
    },
    "product": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "promise",
        "target_user",
        "first_release_outcome"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "promise": {
          "type": "string",
          "minLength": 1
        },
        "target_user": {
          "type": "string",
          "minLength": 1
        },
        "first_release_outcome": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package_name",
        "module_name",
        "entrypoint",
        "language",
        "runtime",
        "interface"
      ],
      "properties": {
        "package_name": {
          "type": "string",
          "pattern": "^[a-z_][a-z0-9_]*$"
        },
        "module_name": {
          "type": "string",
          "pattern": "^[a-z_][a-z0-9_]*$"
        },
        "entrypoint": {
          "type": "string",
          "minLength": 1
        },
        "language": {
          "type": "string",
          "enum": [
            "python"
          ]
        },
        "runtime": {
          "type": "string",
          "minLength": 1
        },
        "interface": {
          "type": "string",
          "enum": [
            "http"
          ]
        }
      }
    },
    "docs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_files",
        "founder_surfaces"
      ],
      "properties": {
        "canonical_files": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "founder_surfaces": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_checks",
        "smoke_test_command",
        "ci_workflow",
        "uses_git_hooks"
      ],
      "properties": {
        "local_checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "smoke_test_command": {
          "type": "string",
          "minLength": 1
        },
        "ci_workflow": {
          "type": "string",
          "minLength": 1
        },
        "uses_git_hooks": {
          "type": "boolean"
        }
      }
    },
    "environments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "purpose",
          "approval_required",
          "rollback_required"
        ],
        "properties": {
          "name": {
            "type": "string",
            "enum": [
              "local",
              "staging",
              "prod"
            ]
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "approval_required": {
            "type": "boolean"
          },
          "rollback_required": {
            "type": "boolean"
          }
        }
      }
    },
    "controls": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_roles",
        "supported_gates",
        "release_strategies"
      ],
      "properties": {
        "review_roles": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "supported_gates": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "release_strategies": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "direct",
              "staged-rollout",
              "canary"
            ]
          }
        }
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "data_class": {
          "type": "string",
          "enum": [
            "public",
            "internal",
            "confidential",
            "restricted"
          ]
        },
        "compliance_posture": {
          "type": "string",
          "minLength": 1
        },
        "deployment_posture": {
          "type": "string",
          "enum": [
            "founder-approved",
            "team-approved"
          ]
        }
      }
    }
  }
}
